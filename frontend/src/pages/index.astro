---
layout: ../layouts/Layout.astro
title: Portfolio Site
---

<script>
  // Define the structure for content blocks
  const contentPromises = {
    title: fetch('/api/content/hero_title').then(res => res.json()),
    project1Name: fetch('/api/content/project_1_name').then(res => res.json()),
    project1Desc: fetch('/api/content/project_1_description').then(res => res.json()),
    project1Image: fetch('/api/content/project_1_image_data_url').then(res => res.json()), // Hypothetical key for image
  };

  // Utility to render content safely
  function renderContent() {
    const app = document.getElementById('app');
    
    Promise.all([
      contentPromises.title, 
      contentPromises.project1Name, 
      contentPromises.project1Desc, 
      contentPromises.project1Image
    ]).then(([titleData, p1NameData, p1DescData, p1ImgData]) => {
      
      const titleText = titleData.content_text || 'Welcome!';
      const p1Name = p1NameData.content_text || 'Loading Project 1...';
      const p1Desc = p1DescData.content_text || '';
      // Use the Data URL directly if available, otherwise default image
      const p1ImageUrl = p1ImgData.content_image_data_url || 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><rect width="100%" height="100%" fill="%23eee"/></svg>';

      app.innerHTML = `
        <h1>${titleText}</h1>
        
        <section style="border: 1px solid #ccc; padding: 20px; margin-top: 20px;">
          <h2>${p1Name}</h2>
          <p>${p1Desc}</p>
          <img src="${p1ImageUrl}" alt="${p1Name}" style="max-width: 100%; height: auto;">
        </section>
        
        <p>(Content loaded dynamically from Worker API)</p>
      `;

    }).catch(error => {
      console.error("Error loading portfolio data:", error);
      app.innerHTML = `<p style="color: red;">Error loading content. Is the Worker running and correctly bound to D1?</p>`;
    });
  }

  document.addEventListener('astro:page-load', renderContent);
  document.addEventListener('DOMContentLoaded', renderContent); // Initial load safeguard
</script>

<div id="app">
    Loading portfolio site... (If this does not change, check Worker connection)
</div>

<style>
  /* Basic styling */
  body { font-family: sans-serif; padding: 20px; }
  h1 { color: #333; }
</style>