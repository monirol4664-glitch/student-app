---
// frontend/src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<script define:vars={Astro.config.base} is:inline>
			// This script line is a placeholder to ensure Astro hydration works if needed
		</script>
	</head>
	<body>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	/* Global styles */
	:root {
		font-family: sans-serif;
	}
</style>